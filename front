const alertsSeed = [
  {
    id: 1,
    symbol: "SOLUSDT",
    side: "SHORT",
    message: "Setup validé avec RR > 2 et volatilité compatible.",
    timestamp: "18:42",
  },
  {
    id: 2,
    symbol: "BTCUSDT",
    side: "LONG",
    message: "Pullback confirmé, levier modéré conseillé.",
    timestamp: "18:39",
  },
];

function decisionLabel(decision) {
  if (decision === "LONG") return "Long";
  if (decision === "SHORT") return "Short";
  return "Neutre";
}

function decisionIcon(decision) {
  if (decision === "LONG") return <TrendingUp className="h-4 w-4" />;
  if (decision === "SHORT") return <TrendingDown className="h-4 w-4" />;
  return <PauseCircle className="h-4 w-4" />;
}

function decisionBadgeClass(decision) {
  if (decision === "LONG") return "bg-emerald-500/15 text-emerald-400 border-emerald-500/30";
  if (decision === "SHORT") return "bg-red-500/15 text-red-400 border-red-500/30";
  return "bg-slate-500/15 text-slate-300 border-slate-500/30";
}

function formatPrice(value) {
  if (!value) return "-";
  return new Intl.NumberFormat("fr-FR", { maximumFractionDigits: 2 }).format(value);
}

export default function TradingSignalWebApp() {
  const [assets, setAssets] = useState(initialAssets);
  const [alerts, setAlerts] = useState(alertsSeed);
  const [selectedSymbol, setSelectedSymbol] = useState(initialAssets[0].symbol);
  const [newAsset, setNewAsset] = useState("");
  const [timeframe, setTimeframe] = useState("15m");
  const [search, setSearch] = useState("");
  const [notificationsEnabled, setNotificationsEnabled] = useState(true);

  const filteredAssets = useMemo(() => {
    return assets.filter((asset) => asset.symbol.toLowerCase().includes(search.toLowerCase()));
  }, [assets, search]);

  const selectedAsset = useMemo(() => {
    return assets.find((asset) => asset.symbol === selectedSymbol) || assets[0];
  }, [assets, selectedSymbol]);

  const stats = useMemo(() => {
    const enabled = assets.filter((a) => a.enabled).length;
    const opportunities = assets.filter((a) => a.enabled && a.decision !== "NO_TRADE").length;
    const longCount = assets.filter((a) => a.enabled && a.decision === "LONG").length;
    const shortCount = assets.filter((a) => a.enabled && a.decision === "SHORT").length;
    return { enabled, opportunities, longCount, shortCount };
  }, [assets]);

  const addAsset = () => {
    const symbol = newAsset.trim().toUpperCase();
    if (!symbol) return;
    if (assets.some((a) => a.symbol === symbol)) {
      setNewAsset("");
      return;
    }

    const created = {
      symbol,
      enabled: true,
      price: 0,
      change24h: 0,
      timeframe,
      decision: "NO_TRADE",
      score: 0,
      confidence: 0,
      entry: 0,
      stopLoss: 0,
      takeProfit: 0,
      leverage: "-",
      rr: 0,
      reason: "En attente d'analyse temps réel.",
      status: "watching",
      lastAlert: "Aucune",
    };

    setAssets((prev) => [created, ...prev]);
    setSelectedSymbol(symbol);
    setNewAsset("");
  };

  const removeAsset = (symbol) => {
    const next = assets.filter((a) => a.symbol !== symbol);
    setAssets(next);
    if (selectedSymbol === symbol && next.length) {
      setSelectedSymbol(next[0].symbol);
    }
  };

  const toggleAsset = (symbol) => {
    setAssets((prev) =>
      prev.map((asset) =>
        asset.symbol === symbol
          ? {
              ...asset,
              enabled: !asset.enabled,
              status: !asset.enabled ? "watching" : "disabled",
              reason: !asset.enabled ? "Surveillance réactivée." : "Actif désactivé de la surveillance.",
            }
          : asset
      )
    );
  };

  const runScan = () => {
    setAssets((prev) =>
      prev.map((asset) => {
        if (!asset.enabled) return asset;

        const random = Math.random();
        let decision = "NO_TRADE";
        if (random > 0.7) decision = "LONG";
        else if (random < 0.3) decision = "SHORT";

        const score = Math.floor(40 + Math.random() * 50);
        const confidence = Math.floor(35 + Math.random() * 55);
        const basePrice = asset.price || Number((20 + Math.random() * 80000).toFixed(2));
        const entry = Number((basePrice * (1 + (Math.random() - 0.5) * 0.01)).toFixed(2));
        const stopLoss =
          decision === "LONG"
            ? Number((entry * 0.985).toFixed(2))
            : decision === "SHORT"
              ? Number((entry * 1.015).toFixed(2))
              : 0;
        const takeProfit =
          decision === "LONG"
            ? Number((entry * 1.03).toFixed(2))
            : decision === "SHORT"
              ? Number((entry * 0.97).toFixed(2))
              : 0;
        const rr = decision === "NO_TRADE" ? 0 : 2 + Math.random() * 0.8;

        return {
          ...asset,
          decision,
          score,
          confidence,
          entry,
          stopLoss,
          takeProfit,
          rr: Number(rr.toFixed(2)),
          leverage: decision === "NO_TRADE" ? "-" : score > 75 ? "x2" : "x1",
          status: decision === "NO_TRADE" ? "watching" : "opportunity",
          reason:
            decision === "LONG"
              ? "Momentum haussier détecté avec structure favorable et risque maîtrisé."
              : decision === "SHORT"
                ? "Signal vendeur exploitable avec invalidation technique claire."
                : "Aucun setup suffisamment propre pour déclencher une alerte.",
          lastAlert: decision === "NO_TRADE" ? asset.lastAlert : "À l'instant",
        };
      })
    );

    const tradable = assets.find((a) => a.enabled);
    if (tradable) {
      setAlerts((prev) => [
        {
          id: Date.now(),
          symbol: tradable.symbol,
          side: Math.random() > 0.5 ? "LONG" : "SHORT",
          message: "Nouveau scan exécuté, vérifier si l'opportunité est toujours valide à la clôture.",
          timestamp: new Date().toLocaleTimeString("fr-FR", { hour: "2-digit", minute: "2-digit" }),
        },
        ...prev,
      ].slice(0, 8));
    }
  };

  return (
    <div className="min-h-screen bg-slate-950 text-slate-100">
      <div className="mx-auto max-w-7xl p-4 md:p-6">
        <motion.div
          initial={{ opacity: 0, y: 10 }}
          animate={{ opacity: 1, y: 0 }}
          className="mb-6 flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between"
        >
          <div>
            <div className="mb-2 inline-flex items-center gap-2 rounded-full border border-cyan-500/20 bg-cyan-500/10 px-3 py-1 text-xs text-cyan-300">
              <Activity className="h-3.5 w-3.5" />
              Trading Signal Control Center
            </div>
            <h1 className="text-3xl font-semibold tracking-tight">Scanner crypto temps réel</h1>
            <p className="mt-1 text-sm text-slate-400">
              Surveille les actifs, détecte les opportunités long ou short et prépare des alertes exploitables.
            </p>
          </div>

          <div className="flex flex-wrap items-center gap-3">
            <div className="flex items-center gap-2 rounded-2xl border border-slate-800 bg-slate-900 px-3 py-2">
              {notificationsEnabled ? <BellRing className="h-4 w-4 text-cyan-300" /> : <Bell className="h-4 w-4 text-slate-400" />}
              <span className="text-sm text-slate-300">Alertes</span>
              <Switch checked={notificationsEnabled} onCheckedChange={setNotificationsEnabled} />
            </div>
            <Button onClick={runScan} className="rounded-2xl bg-cyan-500 text-slate-950 hover:bg-cyan-400">
              <RefreshCw className="mr-2 h-4 w-4" />
              Lancer un scan
            </Button>
          </div>
        </motion.div>

        <div className="mb-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {[
            { label: "Actifs surveillés", value: stats.enabled, icon: BarChart3 },
            { label: "Opportunités actives", value: stats.opportunities, icon: Target },
            { label: "Longs détectés", value: stats.longCount, icon: TrendingUp },
            { label: "Shorts détectés", value: stats.shortCount, icon: TrendingDown },
          ].map((item) => (
            <Card key={item.label} className="rounded-3xl border-slate-800 bg-slate-900/70 shadow-2xl shadow-black/20">
              <CardContent className="flex items-center justify-between p-5">
                <div>
                  <p className="text-sm text-slate-400">{item.label}</p>
                  <p className="mt-1 text-3xl font-semibold">{item.value}</p>
                </div>
                <div className="rounded-2xl border border-slate-700 bg-slate-950 p-3 text-cyan-300">
                  <item.icon className="h-5 w-5" />
                </div>
              </CardContent>
            </Card>
          ))}
        </div>

        <div className="grid gap-6 xl:grid-cols-[380px_minmax(0,1fr)]">
          <div className="space-y-6">
            <Card className="rounded-3xl border-slate-800 bg-slate-900/70">
              <CardHeader>
                <CardTitle className="text-lg">Watchlist</CardTitle>
              </CardHeader>
              <CardContent className="space-y-4">
                <div className="flex gap-2">
                  <div className="relative flex-1">
                    <Search className="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-500" />
                    <Input
                      value={search}
                      onChange={(e) => setSearch(e.target.value)}
                      placeholder="Rechercher un actif"
                      className="rounded-2xl border-slate-800 bg-slate-950 pl-9 text-slate-100"
                    />
                  </div>
                </div>

                <div className="flex gap-2">
                  <Input
                    value={newAsset}
                    onChange={(e) => setNewAsset(e.target.value)}
                    placeholder="Ex: XRPUSDT"
                    className="rounded-2xl border-slate-800 bg-slate-950 text-slate-100"
                  />
                  <Select value={timeframe} onValueChange={setTimeframe}>
                    <SelectTrigger className="w-28 rounded-2xl border-slate-800 bg-slate-950">
                      <SelectValue />
                    </SelectTrigger>
                    <SelectContent>
                      <SelectItem value="5m">5m</SelectItem>
                      <SelectItem value="15m">15m</SelectItem>
                      <SelectItem value="1h">1h</SelectItem>
                      <SelectItem value="4h">4h</SelectItem>
                    </SelectContent>
                  </Select>
                  <Button onClick={addAsset} className="rounded-2xl bg-emerald-500 text-slate-950 hover:bg-emerald-400">
                    <Plus className="h-4 w-4" />
                  </Button>
                </div>

                <div className="space-y-3">
                  {filteredAssets.map((asset) => (
                    <button
                      key={asset.symbol}
                      onClick={() => setSelectedSymbol(asset.symbol)}
                      className={`w-full rounded-2xl border p-4 text-left transition ${selectedSymbol === asset.symbol ? "border-cyan-500/40 bg-cyan-500/10" : "border-slate-800 bg-slate-950/70 hover:border-slate-700"}`}
                    >
                      <div className="mb-3 flex items-start justify-between gap-3">
                        <div>
                          <div className="font-medium">{asset.symbol}</div>
                          <div className="text-xs text-slate-500">Timeframe {asset.timeframe}</div>
                        </div>
                        <Badge className={`border ${decisionBadgeClass(asset.decision)}`}>
                          <span className="mr-1">{decisionIcon(asset.decision)}</span>
                          {decisionLabel(asset.decision)}
                        </Badge>
                      </div>

                      <div className="mb-3 grid grid-cols-2 gap-3 text-sm">
                        <div>
                          <div className="text-slate-500">Prix</div>
                          <div>{formatPrice(asset.price)}</div>
                        </div>
                        <div>
                          <div className="text-slate-500">24h</div>
                          <div className={asset.change24h >= 0 ? "text-emerald-400" : "text-red-400"}>
                            {asset.change24h >= 0 ? "+" : ""}
                            {asset.change24h}%
                          </div>
                        </div>
                      </div>

                      <div className="mb-3 flex items-center gap-3">
                        <div className="flex-1">
                          <div className="mb-1 flex justify-between text-xs text-slate-500">
                            <span>Score</span>
                            <span>{asset.score}/100</span>
                          </div>
                          <Progress value={asset.score} className="h-2 bg-slate-800" />
                        </div>
                      </div>

                      <div className="flex items-center justify-between">
                        <div className="flex items-center gap-2 text-xs text-slate-500">
                          <span>Actif</span>
                          <Switch checked={asset.enabled} onCheckedChange={() => toggleAsset(asset.symbol)} />
                        </div>
                        <Button
                          variant="ghost"
                          size="icon"
                          className="h-8 w-8 rounded-xl text-slate-400 hover:bg-red-500/10 hover:text-red-400"
                          onClick={(e) => {
                            e.stopPropagation();
                            removeAsset(asset.symbol);
                          }}
                        >
                          <Trash2 className="h-4 w-4" />
                        </Button>
                      </div>
                    </button>
                  ))}
                </div>
              </CardContent>
            </Card>

            <Card className="rounded-3xl border-slate-800 bg-slate-900/70">
              <CardHeader>
                <CardTitle className="text-lg">Dernières alertes</CardTitle>
              </CardHeader>
              <CardContent className="space-y-3">
                {alerts.map((alert) => (
                  <div key={alert.id} className="rounded-2xl border border-slate-800 bg-slate-950/70 p-4">
                    <div className="mb-2 flex items-center justify-between">
                      <div className="font-medium">{alert.symbol}</div>
                      <Badge className={`border ${decisionBadgeClass(alert.side)}`}>{alert.side}</Badge>
                    </div>
                    <p className="text-sm text-slate-400">{alert.message}</p>
                    <div className="mt-2 text-xs text-slate-500">{alert.timestamp}</div>
                  </div>
                ))}
              </CardContent>
            </Card>
          </div>

          <div className="space-y-6">
            <Card className="rounded-3xl border-slate-800 bg-slate-900/70">
              <CardHeader className="flex flex-row items-center justify-between">
                <div>
                  <CardTitle className="text-xl">{selectedAsset?.symbol || "Aucun actif"}</CardTitle>
                  <p className="mt-1 text-sm text-slate-400">
                    Analyse détaillée du setup, des niveaux techniques et du risque.
                  </p>
                </div>
                <Badge className={`border text-sm ${decisionBadgeClass(selectedAsset?.decision)}`}>
                  <span className="mr-1">{decisionIcon(selectedAsset?.decision)}</span>
                  {decisionLabel(selectedAsset?.decision)}
                </Badge>
              </CardHeader>
              <CardContent>
                <Tabs defaultValue="setup" className="w-full">
                  <TabsList className="mb-6 grid w-full grid-cols-3 rounded-2xl bg-slate-950">
                    <TabsTrigger value="setup" className="rounded-2xl">Setup</TabsTrigger>
                    <TabsTrigger value="risk" className="rounded-2xl">Risque</TabsTrigger>
                    <TabsTrigger value="config" className="rounded-2xl">Configuration</TabsTrigger>
                  </TabsList>

                  <TabsContent value="setup" className="space-y-6">
                    <div className="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
                      {[
                        { label: "Prix actuel", value: formatPrice(selectedAsset?.price) },
                        { label: "Entrée", value: formatPrice(selectedAsset?.entry) },
                        { label: "Stop loss", value: formatPrice(selectedAsset?.stopLoss) },
                        { label: "Take profit", value: formatPrice(selectedAsset?.takeProfit) },
                      ].map((item) => (
                        <div key={item.label} className="rounded-2xl border border-slate-800 bg-slate-950/70 p-4">
                          <div className="text-sm text-slate-500">{item.label}</div>
                          <div className="mt-1 text-xl font-semibold">{item.value}</div>
                        </div>
                      ))}
                    </div>

                    <div className="grid gap-4 lg:grid-cols-[1.2fr_0.8fr]">
                      <div className="rounded-3xl border border-slate-800 bg-slate-950/70 p-5">
                        <div className="mb-4 flex items-center justify-between">
                          <h3 className="font-medium">Résumé stratégique</h3>
                          <Badge className="border border-slate-700 bg-slate-900 text-slate-300">
                            Dernière alerte : {selectedAsset?.lastAlert}
                          </Badge>
                        </div>
                        <p className="text-sm leading-6 text-slate-300">{selectedAsset?.reason}</p>
                        <div className="mt-5 grid gap-4 md:grid-cols-2">
                          <div>
                            <div className="mb-2 text-sm text-slate-500">Score setup</div>
                            <Progress value={selectedAsset?.score || 0} className="h-3 bg-slate-800" />
                            <div className="mt-2 text-sm text-slate-400">{selectedAsset?.score || 0}/100</div>
                          </div>
                          <div>
                            <div className="mb-2 text-sm text-slate-500">Confiance</div>
                            <Progress value={selectedAsset?.confidence || 0} className="h-3 bg-slate-800" />
                            <div className="mt-2 text-sm text-slate-400">{selectedAsset?.confidence || 0}/100</div>
                          </div>
                        </div>
                      </div>

                      <div className="rounded-3xl border border-slate-800 bg-slate-950/70 p-5">
                        <h3 className="mb-4 font-medium">Verdict</h3>
                        <div className="mb-4 flex items-center gap-3">
                          <div className={`rounded-2xl p-3 ${selectedAsset?.decision === "LONG" ? "bg-emerald-500/15 text-emerald-400" : selectedAsset?.decision === "SHORT" ? "bg-red-500/15 text-red-400" : "bg-slate-500/15 text-slate-300"}`}>
                            {decisionIcon(selectedAsset?.decision)}
                          </div>
                          <div>
                            <div className="text-lg font-semibold">{decisionLabel(selectedAsset?.decision)}</div>
                            <div className="text-sm text-slate-500">Timeframe {selectedAsset?.timeframe}</div>
                          </div>
                        </div>
                        <div className="space-y-3 text-sm text-slate-300">
                          <div className="flex items-center justify-between rounded-2xl border border-slate-800 p-3">
                            <span>Levier conseillé</span>
                            <span className="font-medium">{selectedAsset?.leverage}</span>
                          </div>
                          <div className="flex items-center justify-between rounded-2xl border border-slate-800 p-3">
                            <span>RR estimé</span>
                            <span className="font-medium">{selectedAsset?.rr || 0}</span>
                          </div>
                        </div>
                      </div>
                    </div>
                  </TabsContent>

                  <TabsContent value="risk" className="space-y-4">
                    <div className="grid gap-4 md:grid-cols-3">
                      <div className="rounded-2xl border border-slate-800 bg-slate-950/70 p-4">
                        <div className="mb-2 flex items-center gap-2 text-slate-300"><Shield className="h-4 w-4" /> Risque</div>
                        <div className="text-2xl font-semibold">
                          {selectedAsset?.decision === "NO_TRADE" ? "Élevé / non optimal" : "Modéré"}
                        </div>
                        <p className="mt-2 text-sm text-slate-500">Évaluation basée sur le stop, le RR et la qualité du setup.</p>
                      </div>
                      <div className="rounded-2xl border border-slate-800 bg-slate-950/70 p-4">
                        <div className="mb-2 flex items-center gap-2 text-slate-300"><Target className="h-4 w-4" /> Invalidation</div>
                        <div className="text-2xl font-semibold">{formatPrice(selectedAsset?.stopLoss)}</div>
                        <p className="mt-2 text-sm text-slate-500">Le scénario n'est plus valide si ce niveau est touché.</p>
                      </div>
                      <div className="rounded-2xl border border-slate-800 bg-slate-950/70 p-4">
                        <div className="mb-2 flex items-center gap-2 text-slate-300"><Activity className="h-4 w-4" /> Exposition</div>
                        <div className="text-2xl font-semibold">{selectedAsset?.leverage}</div>
                        <p className="mt-2 text-sm text-slate-500">Levier proposé pour garder une exposition raisonnable.</p>
                      </div>
                    </div>
                    <div className="rounded-3xl border border-slate-800 bg-slate-950/70 p-5 text-sm leading-6 text-slate-300">
                      Cette maquette suppose une logique de gestion du risque centrée sur un profil modéré. Dans la version finale, cette zone devra être branchée à un vrai moteur de calcul qui tient compte de l'ATR, de la volatilité intraday, du capital, du risque par trade et d'un seuil minimal de ratio rendement / risque avant émission d'alerte.
                    </div>
                  </TabsContent>

                  <TabsContent value="config" className="space-y-4">
                    <div className="grid gap-4 md:grid-cols-2">
                      <div className="rounded-2xl border border-slate-800 bg-slate-950/70 p-4">
                        <div className="mb-3 flex items-center gap-2 text-slate-300"><Settings className="h-4 w-4" /> Paramètres d'alerte</div>
                        <div className="space-y-3 text-sm text-slate-300">
                          <div className="flex items-center justify-between rounded-2xl border border-slate-800 p-3">
                            <span>Notifications actives</span>
                            <Switch checked={notificationsEnabled} onCheckedChange={setNotificationsEnabled} />
                          </div>
                          <div className="flex items-center justify-between rounded-2xl border border-slate-800 p-3">
                            <span>Canal prioritaire</span>
                            <span className="font-medium">Telegram</span>
                          </div>
                          <div className="flex items-center justify-between rounded-2xl border border-slate-800 p-3">
                            <span>Cooldown anti-spam</span>
                            <span className="font-medium">15 min</span>
                          </div>
                        </div>
                      </div>
                      <div className="rounded-2xl border border-slate-800 bg-slate-950/70 p-4">
                        <div className="mb-3 flex items-center gap-2 text-slate-300"><BarChart3 className="h-4 w-4" /> Paramètres stratégie</div>
